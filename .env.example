# Local API runtime
DATABASE_URL=postgresql://dialect:dialect_dev_only@localhost:5432/dialect_factory
DATA_DIR=./data
HOST=0.0.0.0
PORT=8000

# Docker Postgres
POSTGRES_DB=dialect_factory
POSTGRES_USER=dialect
POSTGRES_PASSWORD=dialect_dev_only
POSTGRES_PORT=5432

# Add the day-of credential locally; never commit it.
GEMINI_API_KEY=

# Shared demo-only key sent as X-Deck-Admin-Key to deck-control endpoints.
DECK_ADMIN_API_KEY=

# Host-only Gemma Tune UI supervisor. Point these at one frozen preparation
# and its separately verified full adapter; never expose these paths to clients.
TUNE_MODEL_ID=unsloth/gemma-4-E4B-it-unsloth-bnb-4bit
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
TUNE_DEMO_RUNTIME_ROOT=./data/tune-demo
TUNE_DEMO_PREPARED_DIR=
TUNE_DEMO_FULL_ADAPTER=
TUNE_DEMO_ARTIFACT_MANIFEST=
TUNE_DEMO_RUN_ROOT=./data/tune-demo/runs
TUNE_DEMO_APPROVED_PREDICTIONS=
TUNE_DEMO_APPROVED_SAMPLE_IDS=
TUNE_DEMO_UPLOAD_TTL_SECONDS=3600
